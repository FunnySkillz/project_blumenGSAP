---
import "../styles/global.css";

const storyChapters = [
  {
    number: "00",
    time: "Geburtstag",
    label: "Freude",
    kicker: "Für Geburtstage",
    headline: "Damit der Tag wirklich ihr Tag ist.",
    title: "Wenn der Tag jemandem gehören soll.",
    text: "Ein Geburtstagsstrauß sagt: Ich habe an dich gedacht. Jelena bindet ihn so, dass er nicht beliebig wirkt, sondern genau zur Person passt.",
    image:
      "https://images.unsplash.com/photo-1508610048659-a06b669e3321?auto=format&fit=crop&w=1500&q=90",
    accent: "#f2b8bd",
  },
  {
    number: "01",
    time: "Hochzeit",
    label: "Ja",
    kicker: "Für Hochzeiten",
    headline: "Für ein Ja, das nachklingen soll.",
    title: "Wenn ein Ja Blumen braucht.",
    text: "Für Hochzeit, Standesamt oder den kleinen festlichen Tisch braucht es Blumen mit Ruhe, Farbe und Haltung. Kein Standardstrauß, sondern ein Gefühl.",
    image:
      "https://images.unsplash.com/photo-1526045478516-99145907023c?auto=format&fit=crop&w=1500&q=90",
    accent: "#e8b95e",
  },
  {
    number: "02",
    time: "Danke",
    label: "Wertschätzung",
    kicker: "Zum Danke sagen",
    headline: "Wenn Danke mehr Raum braucht.",
    title: "Wenn Danke zu klein klingt.",
    text: "Manchmal reicht eine Nachricht nicht. Ein sorgfältig gebundener Strauß macht sichtbar, dass jemand wirklich geholfen, getragen oder begleitet hat.",
    image:
      "https://images.unsplash.com/photo-1519378058457-4c29a0a2efac?auto=format&fit=crop&w=1500&q=90",
    accent: "#d96b74",
  },
  {
    number: "03",
    time: "Entschuldigung",
    label: "Nähe",
    kicker: "Zur Entschuldigung",
    headline: "Wenn ein ehrlicher Schritt sichtbar werden soll.",
    title: "Wenn Worte allein nicht reichen.",
    text: "Blumen lösen nicht alles, aber sie öffnen eine Tür. Jelena hilft, den Ton zu finden: ehrlich, warm und nicht zu viel.",
    image:
      "https://images.unsplash.com/photo-1494972308805-463bc619d34e?auto=format&fit=crop&w=1500&q=90",
    accent: "#c7d2a0",
  },
  {
    number: "04",
    time: "Trauer",
    label: "Stille",
    kicker: "In stillen Momenten",
    headline: "Wenn Trost leise bleiben darf.",
    title: "Wenn es leise und würdevoll sein muss.",
    text: "In schweren Momenten zählt Zurückhaltung. Blumen können Trost zeigen, ohne große Worte zu verlangen.",
    image:
      "https://images.unsplash.com/photo-1533616688419-b7a585564566?auto=format&fit=crop&w=1500&q=90",
    accent: "#d7a1c8",
  },
  {
    number: "05",
    time: "Zuhause",
    label: "Ankommen",
    kicker: "Für dein Zuhause",
    headline: "Wenn ein Raum wieder atmen soll.",
    title: "Wenn ein Raum leben soll.",
    text: "Topfpflanzen und frische Blumen verändern ein Zuhause sofort: weicher, lebendiger, persönlicher. Man spürt es, bevor man es erklärt.",
    image:
      "https://images.unsplash.com/photo-1485955900006-10f4d324d411?auto=format&fit=crop&w=1500&q=90",
    accent: "#f5c267",
  },
  {
    number: "06",
    time: "Einfach so",
    label: "Liebe",
    kicker: "Einfach so",
    headline: "Weil Liebe keinen Termin braucht.",
    title: "Wenn es keinen Grund braucht.",
    text: "Die schönsten Blumen kommen manchmal ohne Anlass. Für Freitag. Für den Heimweg. Für einen Menschen, der heute lächeln soll.",
    image:
      "https://images.unsplash.com/photo-1487530811176-3780de880c2d?auto=format&fit=crop&w=1500&q=90",
    accent: "#9bbd8f",
  },
];
---

<!doctype html>
<html lang="de-AT">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Blumen Jelena e.U. in Linz: frische Blumen, Topfpflanzen und liebevolle Geschenkideen in der Raimundstraße 39."
    />
    <meta name="theme-color" content="#101b15" />
    <title>Blumen Jelena | Eine Blumengeschichte aus Linz</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand-mark" href="/" aria-label="Blumen Jelena Startseite">
        <span>BJ</span>
      </a>
      <nav class="site-nav" aria-label="Hauptnavigation">
        <a href="#einladung">Einladung</a>
        <a href="#geschichte">Momente</a>
        <a href="#besuch">Besuch</a>
        <a href="#kontakt">Kontakt</a>
      </nav>
      <a class="header-cta" href="tel:+436765882700">+43 676 5882700</a>
    </header>

    <main>
      <section class="invitation" id="einladung" aria-label="Einladung von Blumen Jelena">
        <div class="invitation__stage">
          <div class="invitation__grain" aria-hidden="true"></div>
          <div class="invitation__copy" aria-hidden="true">
            <span>Scroll</span>
            <span>to open</span>
          </div>

          <div class="envelope-scene" aria-hidden="true">
            <div class="envelope-shadow"></div>
            <div class="envelope">
              <div class="letter">
                <p>Blumen Jelena</p>
                <h1>Eine Geste wartet darauf, geöffnet zu werden.</h1>
                <span>Raimundstraße 39 · Linz</span>
              </div>

              <div class="envelope__back"></div>
              <div class="envelope__flap envelope__flap--top"></div>
              <div class="envelope__pocket envelope__pocket--left"></div>
              <div class="envelope__pocket envelope__pocket--right"></div>
              <div class="envelope__pocket envelope__pocket--bottom"></div>

              <div class="wax-seal">
                <svg viewBox="0 0 100 100" role="img" aria-label="Rotes Wachssiegel mit Krone">
                  <path class="wax-crown" d="M26 58 L30 36 L44 51 L50 29 L56 51 L70 36 L74 58 Z" />
                  <path class="wax-crown-base" d="M29 64 H71" />
                  <circle class="wax-crown-dot" cx="50" cy="24" r="3" />
                </svg>
                <span>BJ</span>
              </div>

              <span class="seal-fragment seal-fragment--one"></span>
              <span class="seal-fragment seal-fragment--two"></span>
              <span class="seal-fragment seal-fragment--three"></span>
            </div>

            <div class="invitation-bloom invitation-bloom--one"></div>
            <div class="invitation-bloom invitation-bloom--two"></div>
            <div class="invitation-bloom invitation-bloom--three"></div>
          </div>
        </div>
      </section>

      <section class="story" id="geschichte" aria-labelledby="story-title">
        <div class="story__stage">
          <div class="story__backdrops" aria-hidden="true">
            {storyChapters.map((chapter, index) => (
              <div
                class={`story-backdrop ${index === 0 ? "is-active" : ""}`}
                style={`--scene-image: url("${chapter.image}"); --accent: ${chapter.accent};`}
              />
            ))}
          </div>

          <div class="story__interface">
            <div class="story-progress" aria-hidden="true">
              <span class="story-progress__time">Geburtstag</span>
              <span class="story-progress__line">
                <span class="story-progress__fill"></span>
              </span>
              <span class="story-progress__count">00 / 06</span>
            </div>

            <div class="story__visual" aria-hidden="true">
              <div class="story-orbit">
                <span class="orbit-ring orbit-ring--outer"></span>
                <span class="orbit-ring orbit-ring--middle"></span>
                <span class="orbit-ring orbit-ring--inner"></span>
              </div>

              <svg class="story-route" viewBox="0 0 620 620">
                <path d="M80 500 C118 360 210 370 226 250 C242 132 355 132 382 230 C410 332 540 318 548 142" />
              </svg>

              {storyChapters.map((chapter, index) => (
                <figure
                  class={`story-media story-media--${index + 1} ${index === 0 ? "is-active" : ""}`}
                  style={`--scene-image: url("${chapter.image}"); --accent: ${chapter.accent};`}
                >
                  <span>{chapter.number}</span>
                </figure>
              ))}

              <div class="story-object story-object--door"></div>
              <div class="story-object story-object--wrap"></div>
              <div class="story-object story-object--tag"></div>
            </div>

            <div class="story__copy">
              <p class="eyebrow story-kicker">{storyChapters[0].kicker}</p>
              <h2 id="story-title">{storyChapters[0].headline}</h2>

              <div class="story-cards">
                {storyChapters.map((chapter, index) => (
                  <article
                    class={`story-card ${index === 0 ? "is-active" : ""}`}
                    data-number={chapter.number}
                    data-time={chapter.time}
                    data-label={chapter.label}
                    data-kicker={chapter.kicker}
                    data-headline={chapter.headline}
                  >
                    <img src={chapter.image} alt="" loading={index === 0 ? "eager" : "lazy"} />
                    <span>{chapter.number}</span>
                    <p>{chapter.time} · {chapter.label}</p>
                    <h3>{chapter.title}</h3>
                    <div>{chapter.text}</div>
                  </article>
                ))}
              </div>

              <div class="story-dots" aria-hidden="true">
                {storyChapters.map((chapter, index) => (
                  <span class={index === 0 ? "is-active" : ""} data-story-dot={index}>
                    {chapter.number}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="arrival" id="besuch" aria-labelledby="arrival-title">
        <div class="arrival__image" data-reveal>
          <img
            src="https://images.unsplash.com/photo-1509719662289-0d4b4f2ea278?auto=format&fit=crop&w=1500&q=90"
            alt="Blumen in warmem Licht"
            loading="lazy"
          />
        </div>
        <div class="arrival__content" data-reveal>
          <p class="eyebrow">Die letzte Szene ist echt</p>
          <h2 id="arrival-title">Komm vorbei, wenn der Moment Blumen braucht.</h2>
          <p>
            Blumen Jelena e.U. ist in der Raimundstraße 39 in 4020 Linz. Für
            frische Schnittblumen, Topfpflanzen und kleine Geschenkideen ist ein
            direkter Anruf oft der schnellste Weg.
          </p>
        </div>
      </section>

      <section class="contact" id="kontakt" aria-labelledby="contact-title">
        <div class="contact__heading" data-reveal>
          <p class="eyebrow">Kontakt</p>
          <h2 id="contact-title">Blumen Jelena e.U.</h2>
        </div>
        <div class="contact__grid">
          <a class="contact-tile" href="https://maps.google.com/?q=Raimundstra%C3%9Fe%2039%2C%204020%20Linz" data-reveal>
            <span>Adresse</span>
            <strong>Raimundstraße 39<br />4020 Linz</strong>
          </a>
          <a class="contact-tile" href="tel:+436765882700" data-reveal>
            <span>Telefon</span>
            <strong>+43 676 5882700</strong>
          </a>
          <a class="contact-tile" href="mailto:info@blumen-jelena.at" data-reveal>
            <span>E-Mail</span>
            <strong>info@blumen-jelena.at</strong>
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>Blumen Jelena e.U. · Raimundstraße 39 · 4020 Linz</p>
      <a href="mailto:info@blumen-jelena.at">info@blumen-jelena.at</a>
    </footer>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!prefersReducedMotion) {
        const mm = gsap.matchMedia();

        gsap.set(".envelope", {
          scale: 0.78,
          y: 60,
          rotateX: 10,
          transformOrigin: "50% 50%",
        });
        gsap.set(".letter", { y: "23%", scale: 0.94 });
        gsap.set(".envelope__flap--top", {
          rotateX: 0,
          transformPerspective: 1400,
          transformOrigin: "50% 0%",
        });
        gsap.set(".invitation__copy", { autoAlpha: 0.72 });

        const invitationTimeline = gsap.timeline({
          scrollTrigger: {
            trigger: ".invitation",
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
            pin: ".invitation__stage",
            anticipatePin: 1,
          },
        });

        invitationTimeline
          .to(".envelope", { scale: 1, y: 0, rotateX: 0, duration: 0.65, ease: "power3.out" }, 0)
          .to(".envelope-shadow", { scaleX: 1.18, autoAlpha: 0.78, duration: 0.65 }, 0)
          .to(".wax-seal", { scale: 1.16, rotate: 7, duration: 0.28, ease: "power2.out" }, 0.34)
          .to(".wax-seal", { scale: 0.42, autoAlpha: 0, x: -94, y: 86, rotate: -96, duration: 0.5, ease: "power3.in" }, 0.62)
          .to(
            ".seal-fragment",
            {
              autoAlpha: 1,
              x: (index) => [-92, 78, -28][index] || 0,
              y: (index) => [92, 64, 128][index] || 0,
              rotate: (index) => [-78, 62, 118][index] || 0,
              scale: (index) => [0.78, 0.64, 0.52][index] || 0.6,
              duration: 0.62,
              stagger: 0.04,
              ease: "power3.out",
            },
            0.58
          )
          .to(".envelope__flap--top", { rotateX: -178, y: -5, duration: 0.84, ease: "power2.inOut" }, 0.76)
          .to(".letter", { y: "-34%", scale: 1.02, duration: 0.78, ease: "power3.out" }, 1.02)
          .to(".envelope__pocket--left", { x: "-4%", rotateZ: -2, duration: 0.52, ease: "power2.out" }, 1.12)
          .to(".envelope__pocket--right", { x: "4%", rotateZ: 2, duration: 0.52, ease: "power2.out" }, 1.12)
          .to(
            ".invitation-bloom",
            {
              autoAlpha: 1,
              scale: (index) => [1.28, 1.1, 1.42][index] || 1.2,
              x: (index) => [-34, 28, 18][index] || 0,
              y: (index) => [18, -24, 36][index] || 0,
              rotate: (index) => [-18, 22, 42][index] || 0,
              duration: 0.72,
              stagger: 0.06,
              ease: "back.out(1.8)",
            },
            1.18
          )
          .to(".letter", { y: "-74%", scale: 1.16, rotateX: 0, duration: 0.82, ease: "power3.inOut" }, 1.72)
          .to(".envelope", { scale: 1.14, y: "8%", duration: 0.82, ease: "power2.inOut" }, 1.76)
          .to(".invitation__copy", { autoAlpha: 0, y: 12, duration: 0.32 }, 1.84)
          .to(".envelope-scene", { autoAlpha: 0, scale: 1.36, filter: "blur(14px)", duration: 0.58, ease: "power2.in" }, 2.45)
          .to(".invitation__grain", { autoAlpha: 0, duration: 0.42 }, 2.52);

        gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((element) => {
          gsap.from(element, {
            autoAlpha: 0,
            y: 46,
            clipPath: "inset(16% 0 0 0)",
            duration: 0.9,
            ease: "power3.out",
            scrollTrigger: {
              trigger: element,
              start: "top 82%",
              once: true,
            },
          });
        });

        mm.add("(min-width: 901px)", () => {
          const cards = gsap.utils.toArray<HTMLElement>(".story-card");
          const media = gsap.utils.toArray<HTMLElement>(".story-media");
          const backdrops = gsap.utils.toArray<HTMLElement>(".story-backdrop");
          const dots = gsap.utils.toArray<HTMLElement>("[data-story-dot]");
          const time = document.querySelector<HTMLElement>(".story-progress__time");
          const count = document.querySelector<HTMLElement>(".story-progress__count");
          const fill = document.querySelector<HTMLElement>(".story-progress__fill");
          const kicker = document.querySelector<HTMLElement>(".story-kicker");
          const headline = document.querySelector<HTMLElement>("#story-title");
          const route = document.querySelector<SVGPathElement>(".story-route path");

          if (cards.length === 0 || media.length === 0 || backdrops.length === 0) {
            return;
          }

          if (route) {
            const routeLength = route.getTotalLength();
            route.style.strokeDasharray = `${routeLength}`;
            route.style.strokeDashoffset = `${routeLength}`;
          }

          let activeScene = -1;

          const setScene = (index: number) => {
            const scene = Math.max(0, Math.min(index, cards.length - 1));
            const card = cards[scene];

            if (scene === activeScene) {
              return;
            }

            activeScene = scene;

            if (time) {
              time.textContent = card.dataset.time || "";
            }

            if (count) {
              const lastNumber = cards[cards.length - 1]?.dataset.number || "06";
              count.textContent = `${card.dataset.number || "00"} / ${lastNumber}`;
            }

            dots.forEach((dot, dotIndex) => {
              dot.classList.toggle("is-active", dotIndex === scene);
            });

            if (kicker && headline) {
              const textTargets = [kicker, headline];

              kicker.textContent = card.dataset.kicker || "";
              headline.textContent = card.dataset.headline || "";

              gsap.fromTo(
                textTargets,
                { autoAlpha: 0, y: 18, filter: "blur(10px)" },
                {
                  autoAlpha: 1,
                  y: 0,
                  filter: "blur(0px)",
                  duration: 0.35,
                  ease: "power3.out",
                  stagger: 0.04,
                  overwrite: true,
                }
              );
            }
          };

          gsap.set(cards, { autoAlpha: 0, y: 54, filter: "blur(14px)" });
          gsap.set(cards[0], { autoAlpha: 1, y: 0, filter: "blur(0px)" });
          gsap.set(media, {
            autoAlpha: 0,
            scale: 0.72,
            y: 90,
            rotate: -18,
            transformOrigin: "50% 82%",
          });
          gsap.set(media[0], { autoAlpha: 1, scale: 1, y: 0, rotate: -5 });
          gsap.set(backdrops, { autoAlpha: 0 });
          gsap.set(backdrops[0], { autoAlpha: 1 });
          gsap.set(".story-object", { autoAlpha: 0, y: 34, scale: 0.82 });
          setScene(0);

          const storyTimeline = gsap.timeline({
            scrollTrigger: {
              trigger: ".story",
              start: "top top",
              end: "bottom bottom",
              scrub: 1,
              pin: ".story__stage",
              anticipatePin: 1,
              onUpdate: (self) => {
                const scene = Math.min(cards.length - 1, Math.floor(self.progress * cards.length));
                setScene(scene);
                if (fill) {
                  gsap.set(fill, { scaleX: self.progress });
                }
              },
            },
          });

          if (route) {
            storyTimeline.to(route, { strokeDashoffset: 0, duration: cards.length - 1 }, 0);
          }

          storyTimeline
            .to(".orbit-ring--outer", { rotate: 54, scale: 1.1, duration: cards.length - 1 }, 0)
            .to(".orbit-ring--middle", { rotate: -42, scale: 0.94, duration: cards.length - 1 }, 0)
            .to(".orbit-ring--inner", { rotate: 88, scale: 1.16, duration: cards.length - 1 }, 0);

          cards.forEach((card, index) => {
            if (index === 0) {
              return;
            }

            const previous = index - 1;
            const position = index;
            const mediaShift = index % 2 === 0 ? -42 : 42;
            const mediaTurn = index % 2 === 0 ? -10 : 10;

            storyTimeline
              .to(cards[previous], { autoAlpha: 0, y: -46, filter: "blur(14px)", duration: 0.34 }, position - 0.35)
              .to(media[previous], { autoAlpha: 0, scale: 1.08, y: -55, rotate: mediaTurn, duration: 0.42 }, position - 0.37)
              .to(backdrops[previous], { autoAlpha: 0, duration: 0.48 }, position - 0.36)
              .fromTo(
                cards[index],
                { autoAlpha: 0, y: 58, filter: "blur(14px)" },
                { autoAlpha: 1, y: 0, filter: "blur(0px)", duration: 0.46 },
                position - 0.04
              )
              .fromTo(
                media[index],
                { autoAlpha: 0, scale: 0.72, y: 90, x: mediaShift, rotate: -mediaTurn },
                { autoAlpha: 1, scale: 1, y: 0, x: 0, rotate: mediaTurn * 0.35, duration: 0.56 },
                position - 0.14
              )
              .to(backdrops[index], { autoAlpha: 1, duration: 0.58 }, position - 0.24);

            if (index === 3) {
              storyTimeline.to(".story-object--wrap", { autoAlpha: 1, y: 0, scale: 1, rotate: 7, duration: 0.42 }, position + 0.2);
            }

            if (index === 4) {
              storyTimeline.to(".story-object--tag", { autoAlpha: 1, y: 0, scale: 1, rotate: -8, duration: 0.42 }, position + 0.15);
            }

            if (index === 6) {
              storyTimeline.to(".story-object--door", { autoAlpha: 1, y: 0, scale: 1, duration: 0.44 }, position + 0.1);
            }
          });

          return () => {
            storyTimeline.kill();
          };
        });

        gsap.to(".arrival__image img", {
          scale: 1.12,
          ease: "none",
          scrollTrigger: {
            trigger: ".arrival",
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        });

        window.addEventListener("load", () => ScrollTrigger.refresh());
      }
    </script>
  </body>
</html>
