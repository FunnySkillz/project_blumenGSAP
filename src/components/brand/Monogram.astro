---
import vintageJUrl from "../../assets/brand/j-simple-vintage.png?url";

interface Props {
  variant: "brand" | "seal";
  ariaLabel?: string;
}

const { variant, ariaLabel } = Astro.props;
const className = `monogram-j monogram-j--${variant}`;
---

<span
  class={className}
  role={ariaLabel ? "img" : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : "true"}
>
  <img src={vintageJUrl} alt="" loading="eager" decoding="async" />
</span>
