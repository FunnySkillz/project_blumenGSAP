---
import Monogram from "../brand/Monogram.astro";
import { contactDetails, navigationLinks } from "../../data/site";
---

<header class="site-header">
  <a class="brand-mark" href="/" aria-label="Blumen Jelena Startseite">
    <Monogram variant="brand" />
  </a>
  <nav class="site-nav" aria-label="Hauptnavigation">
    {navigationLinks.map((link) => <a href={link.href}>{link.label}</a>)}
  </nav>
  <a class="header-cta" href={contactDetails.phoneHref}>{contactDetails.phone}</a>
</header>
